{
  "$defs": {
    "NodePosition": {
      "additionalProperties": false,
      "description": "Canvas 位置；Engine 不读取，仅前端使用。",
      "properties": {
        "x": {
          "default": 0.0,
          "title": "X",
          "type": "number"
        },
        "y": {
          "default": 0.0,
          "title": "Y",
          "type": "number"
        }
      },
      "title": "NodePosition",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "评价任务节点（§2.3.3）。",
  "properties": {
    "contract": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "节点契约；M1.2 W1.2.3 完成后会从 dict 升级为 NodeContract Pydantic 模型。start/end/subflow/memory_task 通常为 None。",
      "title": "Contract"
    },
    "description": {
      "anyOf": [
        {
          "maxLength": 2000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "节点说明",
      "title": "Description"
    },
    "max_retry": {
      "description": "不通过后允许的回流次数；超过转 human_checkpoint",
      "minimum": 0,
      "title": "Max Retry",
      "type": "integer"
    },
    "metadata": {
      "additionalProperties": true,
      "description": "命名空间化扩展字段（D-WG-4）",
      "title": "Metadata",
      "type": "object"
    },
    "node_id": {
      "description": "节点 ID；草案阶段允许 LooseId，实例化后必须是 ULID/UUIDv7",
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Node Id",
      "type": "string"
    },
    "on_fail_next_node_id": {
      "anyOf": [
        {
          "maxLength": 64,
          "minLength": 3,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "二选一：本字段或对应 fail 边",
      "title": "On Fail Next Node Id"
    },
    "on_pass_next_node_id": {
      "anyOf": [
        {
          "maxLength": 64,
          "minLength": 3,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "二选一：本字段或对应 pass 边",
      "title": "On Pass Next Node Id"
    },
    "position": {
      "anyOf": [
        {
          "$ref": "#/$defs/NodePosition"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Canvas 位置；Engine 忽略"
    },
    "tags": {
      "description": "自由标签，用于过滤",
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "target_node_id": {
      "description": "被审查的节点 ID",
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Target Node Id",
      "type": "string"
    },
    "title": {
      "description": "Canvas 标签",
      "maxLength": 120,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "type": {
      "const": "evaluation_task",
      "default": "evaluation_task",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "node_id",
    "title",
    "target_node_id",
    "max_retry"
  ],
  "title": "EvaluationTaskNode",
  "type": "object"
}
