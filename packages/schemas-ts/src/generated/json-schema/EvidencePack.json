{
  "$defs": {
    "CacheMeta": {
      "additionalProperties": false,
      "description": "缓存元（§6）。",
      "properties": {
        "cache_namespace": {
          "default": "",
          "description": "如 <project_id>::context_fragment::<tokenizer>",
          "title": "Cache Namespace",
          "type": "string"
        },
        "fragment_cache_hits": {
          "description": "命中缓存的 fragment_id 列表",
          "items": {
            "type": "string"
          },
          "title": "Fragment Cache Hits",
          "type": "array"
        },
        "invalidated_by": {
          "description": "触发失效的事件",
          "items": {
            "type": "string"
          },
          "title": "Invalidated By",
          "type": "array"
        },
        "ttl_seconds": {
          "default": 86400,
          "description": "默认 24 小时",
          "minimum": 1,
          "title": "Ttl Seconds",
          "type": "integer"
        }
      },
      "title": "CacheMeta",
      "type": "object"
    },
    "Evidence": {
      "additionalProperties": false,
      "description": "单条 Evidence（§2.1）。",
      "properties": {
        "claim": {
          "description": "该证据所支持的核心论点",
          "maxLength": 500,
          "minLength": 1,
          "title": "Claim",
          "type": "string"
        },
        "confidence": {
          "description": "来源可信度",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "created_at": {
          "description": "ISO-8601",
          "title": "Created At",
          "type": "string"
        },
        "evidence_id": {
          "description": "Pack 内唯一；建议格式 ev_<8 字符 base32>",
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "paraphrase": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "模型可读摘要；CitationChecker 优先使用 quote",
          "title": "Paraphrase"
        },
        "priority": {
          "$ref": "#/$defs/Priority",
          "default": "normal",
          "description": "保留优先级"
        },
        "quote": {
          "description": "原文片段（精确引用，不允许改写）",
          "maxLength": 4000,
          "minLength": 1,
          "title": "Quote",
          "type": "string"
        },
        "relevance": {
          "description": "与节点 purpose 的相关性",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Relevance",
          "type": "number"
        },
        "sensitive": {
          "default": false,
          "description": "敏感数据标记",
          "title": "Sensitive",
          "type": "boolean"
        },
        "source": {
          "discriminator": {
            "mapping": {
              "mcp_resource": "#/$defs/McpResourceEvidenceSource",
              "project_memory": "#/$defs/ProjectMemoryEvidenceSource",
              "reference_chunk": "#/$defs/ReferenceChunkEvidenceSource",
              "tool_result": "#/$defs/ToolResultEvidenceSource",
              "upstream_artifact": "#/$defs/UpstreamArtifactEvidenceSource",
              "user_input": "#/$defs/UserInputEvidenceSource"
            },
            "propertyName": "source_kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/ReferenceChunkEvidenceSource"
            },
            {
              "$ref": "#/$defs/UpstreamArtifactEvidenceSource"
            },
            {
              "$ref": "#/$defs/ToolResultEvidenceSource"
            },
            {
              "$ref": "#/$defs/McpResourceEvidenceSource"
            },
            {
              "$ref": "#/$defs/UserInputEvidenceSource"
            },
            {
              "$ref": "#/$defs/ProjectMemoryEvidenceSource"
            }
          ],
          "title": "Source"
        },
        "support_polarity": {
          "$ref": "#/$defs/SupportPolarity",
          "default": "supports",
          "description": "对 claim 的极性"
        },
        "tokens_estimate": {
          "description": "渲染后 token 估算（含引用元信息）",
          "minimum": 0,
          "title": "Tokens Estimate",
          "type": "integer"
        },
        "topics": {
          "description": "主题标签，用于覆盖度统计",
          "items": {
            "type": "string"
          },
          "title": "Topics",
          "type": "array"
        }
      },
      "required": [
        "evidence_id",
        "claim",
        "quote",
        "source",
        "relevance",
        "confidence",
        "tokens_estimate",
        "created_at"
      ],
      "title": "Evidence",
      "type": "object"
    },
    "EvidenceConflict": {
      "additionalProperties": false,
      "description": "证据冲突（§4.1）。",
      "properties": {
        "auto_detected_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "检测器；如 evidence_builder/conflict_detector_v1",
          "title": "Auto Detected By"
        },
        "conflict_id": {
          "maxLength": 64,
          "minLength": 3,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
          "title": "Conflict Id",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 2,
          "title": "Evidence Ids",
          "type": "array"
        },
        "kind": {
          "$ref": "#/$defs/EvidenceConflictKind"
        },
        "resolution_hint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolution Hint"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        }
      },
      "required": ["conflict_id", "evidence_ids", "kind", "severity"],
      "title": "EvidenceConflict",
      "type": "object"
    },
    "EvidenceConflictKind": {
      "description": "EvidenceConflict.kind。",
      "enum": [
        "contradiction",
        "numeric_disagreement",
        "scope_mismatch",
        "temporal_mismatch",
        "source_credibility_gap"
      ],
      "title": "EvidenceConflictKind",
      "type": "string"
    },
    "EvidenceCoverage": {
      "additionalProperties": false,
      "description": "覆盖度（§3.1）。",
      "properties": {
        "avg_confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Avg Confidence",
          "type": "number"
        },
        "avg_relevance": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Avg Relevance",
          "type": "number"
        },
        "coverage_ratio": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Coverage Ratio",
          "type": "number"
        },
        "evidence_density": {
          "default": 0.0,
          "description": "每千字结论文本的平均 evidence 数",
          "minimum": 0.0,
          "title": "Evidence Density",
          "type": "number"
        },
        "required_topics": {
          "description": "NodeContract 期望覆盖的主题",
          "items": {
            "type": "string"
          },
          "title": "Required Topics",
          "type": "array"
        },
        "required_topics_covered": {
          "description": "已覆盖的主题（子集）",
          "items": {
            "type": "string"
          },
          "title": "Required Topics Covered",
          "type": "array"
        },
        "unsupported_claim_estimates": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "由 CitationChecker 在 evaluation 阶段回填（D-EP-5：构建期不写入）",
          "title": "Unsupported Claim Estimates"
        }
      },
      "required": ["coverage_ratio", "avg_relevance", "avg_confidence"],
      "title": "EvidenceCoverage",
      "type": "object"
    },
    "EvidenceProvenance": {
      "additionalProperties": false,
      "description": "Pack 产生来源（§5.2）。",
      "properties": {
        "builder_version": {
          "description": "EvidenceBuilder 版本",
          "title": "Builder Version",
          "type": "string"
        },
        "built_at": {
          "description": "ISO-8601",
          "title": "Built At",
          "type": "string"
        },
        "embedding_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "如 bge-m3",
          "title": "Embedding Model"
        },
        "pack_hash": {
          "description": "EvidencePack 整体（去时间戳）的稳定 hash",
          "minLength": 1,
          "title": "Pack Hash",
          "type": "string"
        },
        "re_ranker_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "如 claude-haiku-rerank",
          "title": "Re Ranker Model"
        },
        "reference_index_snapshot_id": {
          "minLength": 1,
          "title": "Reference Index Snapshot Id",
          "type": "string"
        },
        "requirements_hash": {
          "minLength": 1,
          "title": "Requirements Hash",
          "type": "string"
        }
      },
      "required": [
        "builder_version",
        "built_at",
        "reference_index_snapshot_id",
        "requirements_hash",
        "pack_hash"
      ],
      "title": "EvidenceProvenance",
      "type": "object"
    },
    "McpResourceEvidenceSource": {
      "additionalProperties": false,
      "properties": {
        "resource_revision": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resource Revision"
        },
        "resource_uri": {
          "description": "MCP Resource URI",
          "minLength": 1,
          "title": "Resource Uri",
          "type": "string"
        },
        "server_id": {
          "minLength": 1,
          "title": "Server Id",
          "type": "string"
        },
        "source_kind": {
          "const": "mcp_resource",
          "default": "mcp_resource",
          "title": "Source Kind",
          "type": "string"
        }
      },
      "required": ["server_id", "resource_uri"],
      "title": "McpResourceEvidenceSource",
      "type": "object"
    },
    "Priority": {
      "description": "ContextFragment.priority / Evidence.priority。",
      "enum": ["critical", "high", "normal", "low"],
      "title": "Priority",
      "type": "string"
    },
    "ProjectMemoryEvidenceSource": {
      "additionalProperties": false,
      "properties": {
        "memory_key": {
          "minLength": 1,
          "title": "Memory Key",
          "type": "string"
        },
        "memory_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Memory Version"
        },
        "source_kind": {
          "const": "project_memory",
          "default": "project_memory",
          "title": "Source Kind",
          "type": "string"
        }
      },
      "required": ["memory_key"],
      "title": "ProjectMemoryEvidenceSource",
      "type": "object"
    },
    "ReferenceChunkEvidenceSource": {
      "additionalProperties": false,
      "properties": {
        "chunk_id": {
          "minLength": 1,
          "title": "Chunk Id",
          "type": "string"
        },
        "chunk_index": {
          "minimum": 0,
          "title": "Chunk Index",
          "type": "integer"
        },
        "page": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "paragraph": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Paragraph"
        },
        "position": {
          "additionalProperties": {
            "type": "integer"
          },
          "description": "{start, end} 字符 / token 偏移",
          "title": "Position",
          "type": "object"
        },
        "reference_id": {
          "minLength": 1,
          "title": "Reference Id",
          "type": "string"
        },
        "reference_title": {
          "description": "冗余便于阅读",
          "minLength": 1,
          "title": "Reference Title",
          "type": "string"
        },
        "reference_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Url"
        },
        "source_kind": {
          "const": "reference_chunk",
          "default": "reference_chunk",
          "title": "Source Kind",
          "type": "string"
        }
      },
      "required": [
        "reference_id",
        "reference_title",
        "chunk_id",
        "chunk_index",
        "position"
      ],
      "title": "ReferenceChunkEvidenceSource",
      "type": "object"
    },
    "RequirementResolution": {
      "additionalProperties": false,
      "description": "RequirementResolution（§5.1）。",
      "properties": {
        "actual_coverage": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Actual Coverage",
          "type": "number"
        },
        "evidence_ids": {
          "description": "用于满足该 requirement 的 evidence 子集",
          "items": {
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "min_coverage": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Min Coverage",
          "type": "number"
        },
        "required_for": {
          "description": "引用产物字段路径（JSONPath）",
          "minLength": 1,
          "title": "Required For",
          "type": "string"
        },
        "requirement_id": {
          "description": "NodeContract 中该 requirement 的稳定 ID",
          "minLength": 1,
          "title": "Requirement Id",
          "type": "string"
        },
        "satisfied": {
          "title": "Satisfied",
          "type": "boolean"
        }
      },
      "required": [
        "requirement_id",
        "required_for",
        "min_coverage",
        "actual_coverage",
        "satisfied"
      ],
      "title": "RequirementResolution",
      "type": "object"
    },
    "Severity": {
      "description": "4 级严重度（failure_taxonomy.md §8）。",
      "enum": ["blocker", "major", "minor", "info"],
      "title": "Severity",
      "type": "string"
    },
    "SupportPolarity": {
      "description": "Evidence.support_polarity。",
      "enum": ["supports", "refutes", "contextual", "unclear"],
      "title": "SupportPolarity",
      "type": "string"
    },
    "ToolResultEvidenceSource": {
      "additionalProperties": false,
      "properties": {
        "arguments_hash": {
          "description": "调用参数 hash，用于回放",
          "minLength": 1,
          "title": "Arguments Hash",
          "type": "string"
        },
        "invocation_id": {
          "minLength": 1,
          "title": "Invocation Id",
          "type": "string"
        },
        "invoked_at": {
          "description": "ISO-8601",
          "title": "Invoked At",
          "type": "string"
        },
        "source_kind": {
          "const": "tool_result",
          "default": "tool_result",
          "title": "Source Kind",
          "type": "string"
        },
        "tool_id": {
          "minLength": 1,
          "title": "Tool Id",
          "type": "string"
        }
      },
      "required": ["tool_id", "invocation_id", "arguments_hash", "invoked_at"],
      "title": "ToolResultEvidenceSource",
      "type": "object"
    },
    "UpstreamArtifactEvidenceSource": {
      "additionalProperties": false,
      "properties": {
        "artifact_field": {
          "minLength": 1,
          "title": "Artifact Field",
          "type": "string"
        },
        "artifact_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Run Id"
        },
        "from_node_id": {
          "maxLength": 64,
          "minLength": 3,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
          "title": "From Node Id",
          "type": "string"
        },
        "source_kind": {
          "const": "upstream_artifact",
          "default": "upstream_artifact",
          "title": "Source Kind",
          "type": "string"
        }
      },
      "required": ["from_node_id", "artifact_field"],
      "title": "UpstreamArtifactEvidenceSource",
      "type": "object"
    },
    "UserInputEvidenceSource": {
      "additionalProperties": false,
      "properties": {
        "asserted_at": {
          "description": "ISO-8601",
          "title": "Asserted At",
          "type": "string"
        },
        "input_field": {
          "minLength": 1,
          "title": "Input Field",
          "type": "string"
        },
        "source_kind": {
          "const": "user_input",
          "default": "user_input",
          "title": "Source Kind",
          "type": "string"
        },
        "user_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "User Id"
        }
      },
      "required": ["input_field", "asserted_at"],
      "title": "UserInputEvidenceSource",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "事实声明的来源边界（§1.1）。\n\n强约束（D-EP-1）：写入完成后到 attempt 结束之间不得修改。",
  "properties": {
    "attempt_id": {
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Attempt Id",
      "type": "string"
    },
    "cache_meta": {
      "anyOf": [
        {
          "$ref": "#/$defs/CacheMeta"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "conflicts": {
      "items": {
        "$ref": "#/$defs/EvidenceConflict"
      },
      "title": "Conflicts",
      "type": "array"
    },
    "coverage": {
      "$ref": "#/$defs/EvidenceCoverage"
    },
    "evidences": {
      "items": {
        "$ref": "#/$defs/Evidence"
      },
      "minItems": 1,
      "title": "Evidences",
      "type": "array"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "node_id": {
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Node Id",
      "type": "string"
    },
    "pack_id": {
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Pack Id",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/EvidenceProvenance"
    },
    "purpose": {
      "description": "本 Pack 服务的事实性问题",
      "maxLength": 500,
      "minLength": 1,
      "title": "Purpose",
      "type": "string"
    },
    "requirements_resolved": {
      "items": {
        "$ref": "#/$defs/RequirementResolution"
      },
      "title": "Requirements Resolved",
      "type": "array"
    },
    "run_id": {
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "pack_id",
    "node_id",
    "attempt_id",
    "run_id",
    "purpose",
    "evidences",
    "coverage",
    "requirements_resolved",
    "provenance"
  ],
  "title": "EvidencePack",
  "type": "object"
}
