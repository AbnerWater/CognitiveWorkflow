        "max_retry": {
          "description": "不通过后允许的回流次数；超过转 human_checkpoint",
          "minimum": 0,
          "title": "Max Retry",
          "type": "integer"
        },
        "metadata": {
          "additionalProperties": true,
          "description": "命名空间化扩展字段（D-WG-4）",
          "title": "Metadata",
          "type": "object"
