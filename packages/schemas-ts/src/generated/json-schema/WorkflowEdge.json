{
  "$defs": {
    "EdgeCondition": {
      "additionalProperties": false,
      "description": "仅 optional / 扩展条件型边使用（§3.3）。",
      "properties": {
        "expression": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "JSON Logic 子集；当 kind=expression 时必填",
          "title": "Expression"
        },
        "kind": {
          "description": "expression / capability / artifact_present / always_false",
          "title": "Kind",
          "type": "string"
        },
        "requires_artifact_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "当 kind=artifact_present 时必填",
          "title": "Requires Artifact Id"
        },
        "requires_capability": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "例：mcp.search.web；当 kind=capability 时必填",
          "title": "Requires Capability"
        }
      },
      "required": [
        "kind"
      ],
      "title": "EdgeCondition",
      "type": "object"
    },
    "EdgeStyle": {
      "additionalProperties": false,
      "description": "渲染样式提示；Engine 忽略。",
      "properties": {
        "color": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Color"
        },
        "dashed": {
          "default": false,
          "title": "Dashed",
          "type": "boolean"
        },
        "width": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Width"
        }
      },
      "title": "EdgeStyle",
      "type": "object"
    },
    "EdgeType": {
      "description": "8 类 WorkflowEdge。",
      "enum": [
        "normal",
        "pass",
        "fail",
        "retry",
        "repair",
        "human",
        "optional",
        "loop"
      ],
      "title": "EdgeType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "图边（§3.1）。",
  "properties": {
    "condition": {
      "anyOf": [
        {
          "$ref": "#/$defs/EdgeCondition"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "edge_id": {
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Edge Id",
      "type": "string"
    },
    "label": {
      "anyOf": [
        {
          "maxLength": 64,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Label"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "source_node_id": {
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Source Node Id",
      "type": "string"
    },
    "style": {
      "anyOf": [
        {
          "$ref": "#/$defs/EdgeStyle"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "target_node_id": {
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Target Node Id",
      "type": "string"
    },
    "type": {
      "$ref": "#/$defs/EdgeType"
    }
  },
  "required": [
    "edge_id",
    "source_node_id",
    "target_node_id",
    "type"
  ],
  "title": "WorkflowEdge",
  "type": "object"
}
