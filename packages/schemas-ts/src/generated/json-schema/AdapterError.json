{
  "$defs": {
    "AdapterErrorKind": {
      "description": "AdapterError.error_kind。",
      "enum": [
        "prepare_failed",
        "invalid_pack",
        "model_request_failed",
        "tool_failed",
        "mcp_transport",
        "approval_required",
        "deferred_tool",
        "output_validation",
        "retry_limit_reached",
        "usage_limit_exceeded",
        "provider_forbidden",
        "cancelled",
        "timeout",
        "adapter_internal"
      ],
      "title": "AdapterErrorKind",
      "type": "string"
    },
    "FailureType": {
      "description": "8+1 类失败分类（D-FT-1 锁定，不允许扩充至 v0.2）。",
      "enum": [
        "format_error",
        "missing_output",
        "missing_evidence",
        "logic_gap",
        "model_capability_limit",
        "tool_error",
        "ambiguous_requirement",
        "review_rule_too_strict",
        "unknown"
      ],
      "title": "FailureType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Adapter 错误结构化记录（agent_adapter.md §7）。",
  "properties": {
    "error_kind": {
      "$ref": "#/$defs/AdapterErrorKind"
    },
    "failure_type": {
      "$ref": "#/$defs/FailureType",
      "description": "对齐 8+1 类"
    },
    "http_status": {
      "anyOf": [
        {
          "maximum": 599,
          "minimum": 100,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Http Status"
    },
    "message": {
      "minLength": 1,
      "title": "Message",
      "type": "string"
    },
    "payload": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Payload"
    },
    "retryable": {
      "title": "Retryable",
      "type": "boolean"
    }
  },
  "required": ["error_kind", "failure_type", "message", "retryable"],
  "title": "AdapterError",
  "type": "object"
}
