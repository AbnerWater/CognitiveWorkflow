{
  "$defs": {
    "AdapterError": {
      "additionalProperties": false,
      "description": "Adapter 错误结构化记录（agent_adapter.md §7）。",
      "properties": {
        "error_kind": {
          "$ref": "#/$defs/AdapterErrorKind"
        },
        "failure_type": {
          "$ref": "#/$defs/FailureType",
          "description": "对齐 8+1 类"
        },
        "http_status": {
          "anyOf": [
            {
              "maximum": 599,
              "minimum": 100,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Http Status"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "payload": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Payload"
        },
        "retryable": {
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": ["error_kind", "failure_type", "message", "retryable"],
      "title": "AdapterError",
      "type": "object"
    },
    "AdapterErrorKind": {
      "description": "AdapterError.error_kind。",
      "enum": [
        "prepare_failed",
        "invalid_pack",
        "model_request_failed",
        "tool_failed",
        "mcp_transport",
        "approval_required",
        "deferred_tool",
        "output_validation",
        "retry_limit_reached",
        "usage_limit_exceeded",
        "provider_forbidden",
        "cancelled",
        "timeout",
        "adapter_internal"
      ],
      "title": "AdapterErrorKind",
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "description": "节点产物引用（stream_event.md §1.5 + agent_adapter.md §6 复用）。",
      "properties": {
        "artifact_id": {
          "maxLength": 64,
          "minLength": 3,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "display_name": {
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "kind": {
          "description": "artifact / pack / evaluation / patch / file / image / chart",
          "title": "Kind",
          "type": "string"
        },
        "mime_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mime Type"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "项目相对路径",
          "title": "Path"
        },
        "preview_text": {
          "anyOf": [
            {
              "maxLength": 500,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preview Text"
        },
        "size_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Size Bytes"
        }
      },
      "required": ["artifact_id", "kind", "display_name"],
      "title": "ArtifactRef",
      "type": "object"
    },
    "AttemptProvenance": {
      "additionalProperties": false,
      "description": "attempt 源信息（agent_adapter.md §6.1）。",
      "properties": {
        "adapter_id": {
          "minLength": 1,
          "title": "Adapter Id",
          "type": "string"
        },
        "adapter_version": {
          "minLength": 1,
          "title": "Adapter Version",
          "type": "string"
        },
        "context_pack_id": {
          "maxLength": 64,
          "minLength": 3,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
          "title": "Context Pack Id",
          "type": "string"
        },
        "evidence_pack_id": {
          "anyOf": [
            {
              "maxLength": 64,
              "minLength": 3,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Pack Id"
        },
        "model_profile_id": {
          "minLength": 1,
          "title": "Model Profile Id",
          "type": "string"
        },
        "model_settings_hash": {
          "description": "实际使用的设置 hash",
          "minLength": 1,
          "title": "Model Settings Hash",
          "type": "string"
        },
        "outcome_hash": {
          "minLength": 1,
          "title": "Outcome Hash",
          "type": "string"
        },
        "pydantic_ai_traceparent": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Adapter=PydanticAI 时回填",
          "title": "Pydantic Ai Traceparent"
        },
        "tools_used": {
          "description": "调用过的 tool / skill / mcp ID",
          "items": {
            "type": "string"
          },
          "title": "Tools Used",
          "type": "array"
        }
      },
      "required": [
        "adapter_id",
        "adapter_version",
        "model_profile_id",
        "model_settings_hash",
        "context_pack_id",
        "outcome_hash"
      ],
      "title": "AttemptProvenance",
      "type": "object"
    },
    "AttemptState": {
      "description": "AgentAdapter.AttemptState（agent_adapter.md §4.1）。",
      "enum": [
        "prepared",
        "running",
        "awaiting_human",
        "completed",
        "failed",
        "cancelled"
      ],
      "title": "AttemptState",
      "type": "string"
    },
    "FailureType": {
      "description": "8+1 类失败分类（D-FT-1 锁定，不允许扩充至 v0.2）。",
      "enum": [
        "format_error",
        "missing_output",
        "missing_evidence",
        "logic_gap",
        "model_capability_limit",
        "tool_error",
        "ambiguous_requirement",
        "review_rule_too_strict",
        "unknown"
      ],
      "title": "FailureType",
      "type": "string"
    },
    "RunUsage": {
      "additionalProperties": false,
      "description": "模型调用 token / cost 用量。\n\n字段与 Pydantic AI `RunUsage` 兼容，便于 Adapter 直接转译。",
      "properties": {
        "cache_creation_input_tokens": {
          "default": 0,
          "minimum": 0,
          "title": "Cache Creation Input Tokens",
          "type": "integer"
        },
        "cache_read_input_tokens": {
          "default": 0,
          "minimum": 0,
          "title": "Cache Read Input Tokens",
          "type": "integer"
        },
        "est_cost_usd": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Est Cost Usd"
        },
        "input_tokens": {
          "default": 0,
          "minimum": 0,
          "title": "Input Tokens",
          "type": "integer"
        },
        "output_tokens": {
          "default": 0,
          "minimum": 0,
          "title": "Output Tokens",
          "type": "integer"
        },
        "requests": {
          "default": 0,
          "minimum": 0,
          "title": "Requests",
          "type": "integer"
        },
        "total_tokens": {
          "default": 0,
          "minimum": 0,
          "title": "Total Tokens",
          "type": "integer"
        }
      },
      "title": "RunUsage",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Adapter.finalize() 返回的最终结果（agent_adapter.md §6）。\n\n与 NodeAttempt 一对一对应。",
  "properties": {
    "attempt_id": {
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Attempt Id",
      "type": "string"
    },
    "duration_ms": {
      "minimum": 0,
      "title": "Duration Ms",
      "type": "integer"
    },
    "errors": {
      "items": {
        "$ref": "#/$defs/AdapterError"
      },
      "title": "Errors",
      "type": "array"
    },
    "finished_at": {
      "description": "ISO-8601",
      "title": "Finished At",
      "type": "string"
    },
    "messages": {
      "anyOf": [
        {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Pydantic AI 风格的完整对话记录；可选",
      "title": "Messages"
    },
    "node_id": {
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Node Id",
      "type": "string"
    },
    "output": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "state=COMPLETED 时；符合 NodeContract.output_schema",
      "title": "Output"
    },
    "output_artifact_refs": {
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "title": "Output Artifact Refs",
      "type": "array"
    },
    "output_hash": {
      "description": "稳定 hash，用于 attempt 复盘",
      "minLength": 1,
      "title": "Output Hash",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/AttemptProvenance"
    },
    "run_id": {
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Run Id",
      "type": "string"
    },
    "started_at": {
      "description": "ISO-8601",
      "title": "Started At",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/AttemptState",
      "description": "终态 COMPLETED / FAILED / CANCELLED"
    },
    "usage": {
      "anyOf": [
        {
          "$ref": "#/$defs/RunUsage"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "attempt_id",
    "run_id",
    "node_id",
    "state",
    "output_hash",
    "started_at",
    "finished_at",
    "duration_ms",
    "provenance"
  ],
  "title": "AttemptOutcome",
  "type": "object"
}
