{
  "$defs": {
    "ArbitrationMode": {
      "description": "EvaluationContract.arbitration（架构 §9 多 Agent 辩论 / D-ER-6）。",
      "enum": ["single_judge", "multi_judge", "programmatic_first"],
      "title": "ArbitrationMode",
      "type": "string"
    },
    "BackoffStrategy": {
      "description": "RetryPolicy.backoff。",
      "enum": ["none", "linear", "exponential"],
      "title": "BackoffStrategy",
      "type": "string"
    },
    "ContextRequirement": {
      "additionalProperties": false,
      "description": "节点上下文需求（§4）。",
      "properties": {
        "key": {
          "description": "该上下文片段在 deps 中的访问键",
          "minLength": 1,
          "title": "Key",
          "type": "string"
        },
        "kind": {
          "description": "来源类型；与 selector.source_kind 必须一致",
          "enum": [
            "upstream_artifact",
            "project_memory",
            "reference",
            "static_text",
            "user_input"
          ],
          "title": "Kind",
          "type": "string"
        },
        "max_tokens": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "单片段 token 上限；超过由 ContextBuilder 摘要",
          "title": "Max Tokens"
        },
        "required": {
          "default": true,
          "description": "缺失时是否阻塞节点",
          "title": "Required",
          "type": "boolean"
        },
        "selector": {
          "description": "来源选择器",
          "discriminator": {
            "mapping": {
              "project_memory": "#/$defs/ProjectMemorySelector",
              "reference": "#/$defs/ReferenceSelector",
              "static_text": "#/$defs/StaticTextSelector",
              "upstream_artifact": "#/$defs/UpstreamArtifactSelector",
              "user_input": "#/$defs/UserInputSelector"
            },
            "propertyName": "source_kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/UpstreamArtifactSelector"
            },
            {
              "$ref": "#/$defs/ProjectMemorySelector"
            },
            {
              "$ref": "#/$defs/ReferenceSelector"
            },
            {
              "$ref": "#/$defs/StaticTextSelector"
            },
            {
              "$ref": "#/$defs/UserInputSelector"
            }
          ],
          "title": "Selector"
        },
        "summarize_if_over": {
          "default": true,
          "description": "超长时是否自动摘要",
          "title": "Summarize If Over",
          "type": "boolean"
        }
      },
      "required": ["key", "kind", "selector"],
      "title": "ContextRequirement",
      "type": "object"
    },
    "EvidenceRequirement": {
      "additionalProperties": false,
      "description": "事实性 / 研究类节点的证据要求。",
      "properties": {
        "min_coverage": {
          "default": 1.0,
          "description": "最小覆盖率阈值",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Min Coverage",
          "type": "number"
        },
        "min_evidences": {
          "default": 1,
          "description": "该 requirement 所需的最少 evidence 数量",
          "minimum": 0,
          "title": "Min Evidences",
          "type": "integer"
        },
        "required_for": {
          "description": "引用产物字段路径（JSONPath）；例：'research_questions[*].source_evidence_ids'",
          "minLength": 1,
          "title": "Required For",
          "type": "string"
        },
        "requirement_id": {
          "default": "",
          "description": "稳定 ID；运行时由 EvidenceBuilder 反查",
          "title": "Requirement Id",
          "type": "string"
        }
      },
      "required": ["required_for"],
      "title": "EvidenceRequirement",
      "type": "object"
    },
    "ExtraValidatorRef": {
      "additionalProperties": false,
      "description": "ValidatorPolicy.extra_validators 引用（§8）。",
      "properties": {
        "options": {
          "additionalProperties": true,
          "description": "校验器参数",
          "title": "Options",
          "type": "object"
        },
        "validator_id": {
          "description": "ToolRegistry 中已注册的校验器 ID（如 citation_checker / schema_strict_v2）",
          "minLength": 1,
          "title": "Validator Id",
          "type": "string"
        }
      },
      "required": ["validator_id"],
      "title": "ExtraValidatorRef",
      "type": "object"
    },
    "FailureType": {
      "description": "8+1 类失败分类（D-FT-1 锁定，不允许扩充至 v0.2）。",
      "enum": [
        "format_error",
        "missing_output",
        "missing_evidence",
        "logic_gap",
        "model_capability_limit",
        "tool_error",
        "ambiguous_requirement",
        "review_rule_too_strict",
        "unknown"
      ],
      "title": "FailureType",
      "type": "string"
    },
    "MCPToolRef": {
      "additionalProperties": false,
      "description": "MCP 工具引用（§5.2）。",
      "properties": {
        "requires_approval": {
          "default": false,
          "description": "调用前需用户批准",
          "title": "Requires Approval",
          "type": "boolean"
        },
        "server_id": {
          "description": "已配置的 MCP Server ID",
          "minLength": 1,
          "title": "Server Id",
          "type": "string"
        },
        "tool_name": {
          "default": "*",
          "description": "限定可调用的 tool 名；'*' = 全部",
          "title": "Tool Name",
          "type": "string"
        }
      },
      "required": ["server_id"],
      "title": "MCPToolRef",
      "type": "object"
    },
    "NodeModelPolicy": {
      "additionalProperties": false,
      "description": "节点级模型策略（§6）。",
      "properties": {
        "candidate_count": {
          "default": 1,
          "description": ">1 时进入 CandidateGenerator + 仲裁",
          "minimum": 1,
          "title": "Candidate Count",
          "type": "integer"
        },
        "escalation_chain": {
          "description": "节点级升级链；为空时使用 Workflow 全局链",
          "items": {
            "type": "string"
          },
          "title": "Escalation Chain",
          "type": "array"
        },
        "forbid_provider_kinds": {
          "description": "禁用的 Provider 类别",
          "items": {
            "$ref": "#/$defs/ProviderKind"
          },
          "title": "Forbid Provider Kinds",
          "type": "array"
        },
        "model_settings": {
          "additionalProperties": true,
          "description": "temperature / top_p / max_tokens / reasoning_effort 等；与 Pydantic AI ModelSettings 兼容",
          "title": "Model Settings",
          "type": "object"
        },
        "primary_model_profile_id": {
          "description": "ModelProfile ID 或 'auto'（走 ModelRouter）",
          "minLength": 1,
          "title": "Primary Model Profile Id",
          "type": "string"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "可重放 seed",
          "title": "Seed"
        }
      },
      "required": ["primary_model_profile_id"],
      "title": "NodeModelPolicy",
      "type": "object"
    },
    "ProjectMemorySelector": {
      "additionalProperties": false,
      "description": "读取项目级 Memory key。",
      "properties": {
        "memory_key": {
          "minLength": 1,
          "title": "Memory Key",
          "type": "string"
        },
        "source_kind": {
          "const": "project_memory",
          "default": "project_memory",
          "title": "Source Kind",
          "type": "string"
        }
      },
      "required": ["memory_key"],
      "title": "ProjectMemorySelector",
      "type": "object"
    },
    "PromptSection": {
      "additionalProperties": false,
      "description": "节点提示词三层结构（§3）。\n\n与 Pydantic AI Agent 的 `system_prompt` / `instructions` / `user_prompt` 三层一致。\n模板变量解析顺序由 ContextBuilder 在装填阶段完成（D-CB-6）；\n此 schema 只承载文本+模板引擎声明。",
      "properties": {
        "instructions": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "动态指令；与 Pydantic AI `instructions` 对齐——支持 RunContext 闭包，编译时只允许引用 deps 字段",
          "title": "Instructions"
        },
        "system_prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "静态系统提示；多段时按顺序拼接",
          "title": "System Prompt"
        },
        "template_engine": {
          "$ref": "#/$defs/TemplateEngine",
          "default": "handlebars",
          "description": "模板渲染引擎（D-NC-1：默认 handlebars）"
        },
        "user_prompt_template": {
          "description": "节点开始时合成的用户提示词；模板支持变量插值 {{ var }}",
          "minLength": 1,
          "title": "User Prompt Template",
          "type": "string"
        }
      },
      "required": ["user_prompt_template"],
      "title": "PromptSection",
      "type": "object"
    },
    "ProviderKind": {
      "description": "ModelProfile.provider_kind / AdapterCapabilities.provider_kinds。",
      "enum": ["cloud", "private", "local"],
      "title": "ProviderKind",
      "type": "string"
    },
    "ReferenceSelector": {
      "additionalProperties": false,
      "description": "读取 ReferenceLibrary 资料；reference_id 可为 '$auto'（由 EvidenceBuilder 候选检索）。",
      "properties": {
        "chunk_filter": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "可选 chunk 过滤条件",
          "title": "Chunk Filter"
        },
        "reference_id": {
          "minLength": 1,
          "title": "Reference Id",
          "type": "string"
        },
        "source_kind": {
          "const": "reference",
          "default": "reference",
          "title": "Source Kind",
          "type": "string"
        }
      },
      "required": ["reference_id"],
      "title": "ReferenceSelector",
      "type": "object"
    },
    "RetryPolicy": {
      "additionalProperties": false,
      "description": "节点级重试策略（§7）。",
      "properties": {
        "backoff": {
          "$ref": "#/$defs/BackoffStrategy",
          "default": "exponential",
          "description": "重试间隔策略"
        },
        "escalation_after": {
          "default": 2,
          "description": "第 N 次失败后允许 ModelRouter 升级模型",
          "minimum": 1,
          "title": "Escalation After",
          "type": "integer"
        },
        "max_attempts": {
          "default": 3,
          "description": "节点的总尝试上限（含首次）",
          "minimum": 1,
          "title": "Max Attempts",
          "type": "integer"
        },
        "model_retries": {
          "default": 2,
          "description": "模型层重试",
          "minimum": 0,
          "title": "Model Retries",
          "type": "integer"
        },
        "output_validation_retries": {
          "default": 2,
          "description": "输出校验失败的重试次数",
          "minimum": 0,
          "title": "Output Validation Retries",
          "type": "integer"
        },
        "timeout_seconds": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "单次 attempt 超时",
          "title": "Timeout Seconds"
        },
        "tool_retries": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "additionalProperties": {
                "type": "integer"
              },
              "type": "object"
            }
          ],
          "default": 2,
          "description": "工具调用重试；可按 tool_id 单独设置",
          "title": "Tool Retries"
        }
      },
      "title": "RetryPolicy",
      "type": "object"
    },
    "SkillRef": {
      "additionalProperties": false,
      "description": "启用的 Skill 引用（§5.1）。",
      "properties": {
        "params": {
          "additionalProperties": true,
          "description": "Skill 参数",
          "title": "Params",
          "type": "object"
        },
        "skill_id": {
          "description": "SkillRegistry 中的 ID",
          "minLength": 1,
          "title": "Skill Id",
          "type": "string"
        },
        "version": {
          "default": "latest",
          "description": "锁定版本；运行时不存在则 L4 报 WG_L4_UNKNOWN_SKILL",
          "title": "Version",
          "type": "string"
        }
      },
      "required": ["skill_id"],
      "title": "SkillRef",
      "type": "object"
    },
    "StaticTextSelector": {
      "additionalProperties": false,
      "description": "直接嵌入静态文本。",
      "properties": {
        "source_kind": {
          "const": "static_text",
          "default": "static_text",
          "title": "Source Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": ["text"],
      "title": "StaticTextSelector",
      "type": "object"
    },
    "TemplateEngine": {
      "description": "PromptSection.template_engine（D-NC-1 默认 handlebars）。",
      "enum": ["handlebars", "jinja2_minimal", "none"],
      "title": "TemplateEngine",
      "type": "string"
    },
    "UpstreamArtifactSelector": {
      "additionalProperties": false,
      "description": "从上游节点产物提取数据。",
      "properties": {
        "artifact_field": {
          "description": "JSONPath；如 'research_questions[*]'",
          "minLength": 1,
          "title": "Artifact Field",
          "type": "string"
        },
        "artifact_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "哪一次 Run；默认当前 run",
          "title": "Artifact Run Id"
        },
        "from_node_id": {
          "description": "上游节点 ID",
          "maxLength": 64,
          "minLength": 3,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
          "title": "From Node Id",
          "type": "string"
        },
        "source_kind": {
          "const": "upstream_artifact",
          "default": "upstream_artifact",
          "title": "Source Kind",
          "type": "string"
        }
      },
      "required": ["from_node_id", "artifact_field"],
      "title": "UpstreamArtifactSelector",
      "type": "object"
    },
    "UserInputSelector": {
      "additionalProperties": false,
      "description": "读取 Run 启动时的初始输入字段。",
      "properties": {
        "input_field": {
          "minLength": 1,
          "title": "Input Field",
          "type": "string"
        },
        "source_kind": {
          "const": "user_input",
          "default": "user_input",
          "title": "Source Kind",
          "type": "string"
        }
      },
      "required": ["input_field"],
      "title": "UserInputSelector",
      "type": "object"
    },
    "ValidatorMode": {
      "description": "ValidatorPolicy.mode。",
      "enum": ["strict", "lenient", "programmatic_only"],
      "title": "ValidatorMode",
      "type": "string"
    },
    "ValidatorPolicy": {
      "additionalProperties": false,
      "description": "节点输出校验策略（§8）。",
      "properties": {
        "arbitration": {
          "$ref": "#/$defs/ArbitrationMode",
          "default": "single_judge",
          "description": "多候选 / 多 judge 仲裁模式（D-NC-7 v0.2 占位）"
        },
        "extra_validators": {
          "description": "ToolRegistry 中已注册的额外校验器（D-NC-3：禁止执行用户代码）",
          "items": {
            "$ref": "#/$defs/ExtraValidatorRef"
          },
          "title": "Extra Validators",
          "type": "array"
        },
        "mode": {
          "$ref": "#/$defs/ValidatorMode",
          "default": "strict",
          "description": "strict：严格校验；lenient：允许部分缺失但触发修复；programmatic_only：跳过 LLM 校验"
        },
        "partial_output_allowed": {
          "default": false,
          "description": "流式中是否允许 partial output（与 Pydantic AI RunContext.partial_output 对齐）",
          "title": "Partial Output Allowed",
          "type": "boolean"
        }
      },
      "title": "ValidatorPolicy",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "确定性工具节点契约（§1.2.5）。\n\n`tool_task` 不调用 LLM；`prompt` / `model_policy` 字段对它无意义。\nL2 校验：发现 prompt 非空将报 NC_L2_TOOL_HAS_PROMPT。",
  "properties": {
    "allowed_tools": {
      "description": "内置工具白名单",
      "items": {
        "type": "string"
      },
      "title": "Allowed Tools",
      "type": "array"
    },
    "args_schema": {
      "additionalProperties": true,
      "description": "入参 JSON Schema",
      "title": "Args Schema",
      "type": "object"
    },
    "context_requirements": {
      "description": "节点对上下文的需求；详见 §4",
      "items": {
        "$ref": "#/$defs/ContextRequirement"
      },
      "title": "Context Requirements",
      "type": "array"
    },
    "contract_id": {
      "description": "ULID/UUIDv7；与节点解耦的唯一 ID，便于跨 Workflow 复用模板",
      "maxLength": 64,
      "minLength": 3,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]{2,63}$",
      "title": "Contract Id",
      "type": "string"
    },
    "contract_kind": {
      "const": "tool",
      "default": "tool",
      "title": "Contract Kind",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "maxLength": 4000,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "节点说明（Canvas / API 文档使用）",
      "title": "Description"
    },
    "evidence_requirements": {
      "description": "仅事实性 / 研究类节点",
      "items": {
        "$ref": "#/$defs/EvidenceRequirement"
      },
      "title": "Evidence Requirements",
      "type": "array"
    },
    "failure_taxonomy": {
      "description": "关注的失败类型子集（D-FT-6：未声明则全 9 类；不在子集内的失败归 unknown）",
      "items": {
        "$ref": "#/$defs/FailureType"
      },
      "title": "Failure Taxonomy",
      "type": "array"
    },
    "forbid_remote_models": {
      "default": false,
      "description": "标记敏感节点；与 WorkflowModelPolicy 配合",
      "title": "Forbid Remote Models",
      "type": "boolean"
    },
    "goal": {
      "description": "节点必须完成的业务目标（业务语言、非 prompt）",
      "maxLength": 2000,
      "minLength": 1,
      "title": "Goal",
      "type": "string"
    },
    "input_schema": {
      "additionalProperties": true,
      "description": "节点入参 JSON Schema",
      "title": "Input Schema",
      "type": "object"
    },
    "mcp_tools": {
      "description": "可调用的 MCP 工具",
      "items": {
        "$ref": "#/$defs/MCPToolRef"
      },
      "title": "Mcp Tools",
      "type": "array"
    },
    "metadata": {
      "additionalProperties": true,
      "description": "命名空间化扩展字段",
      "title": "Metadata",
      "type": "object"
    },
    "model_policy": {
      "$ref": "#/$defs/NodeModelPolicy",
      "description": "节点级模型策略（覆盖 WorkflowModelPolicy）"
    },
    "output_schema": {
      "additionalProperties": true,
      "description": "节点产物 JSON Schema",
      "title": "Output Schema",
      "type": "object"
    },
    "prompt": {
      "anyOf": [
        {
          "$ref": "#/$defs/PromptSection"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "提示词三层结构；execution/evaluation/repair 必填，tool/memory 不允许设置"
    },
    "requires_human_approval": {
      "default": false,
      "description": "高风险节点：成功也走 human_checkpoint（D-NC-5）",
      "title": "Requires Human Approval",
      "type": "boolean"
    },
    "requires_sandbox": {
      "default": true,
      "description": "是否在沙箱中执行",
      "title": "Requires Sandbox",
      "type": "boolean"
    },
    "retry_policy": {
      "$ref": "#/$defs/RetryPolicy",
      "description": "节点级重试"
    },
    "skills": {
      "description": "启用的 Skill",
      "items": {
        "$ref": "#/$defs/SkillRef"
      },
      "title": "Skills",
      "type": "array"
    },
    "tool_id": {
      "description": "ToolRegistry 中的工具 ID",
      "minLength": 1,
      "title": "Tool Id",
      "type": "string"
    },
    "validator_policy": {
      "$ref": "#/$defs/ValidatorPolicy",
      "description": "输出校验策略"
    }
  },
  "required": ["contract_id", "goal", "model_policy", "tool_id"],
  "title": "ToolContract",
  "type": "object"
}
